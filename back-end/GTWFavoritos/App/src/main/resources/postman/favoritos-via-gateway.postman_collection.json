            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"targetMethod\": \"DELETE\",\n  \"queryParams\": {},\n  \"body\": null\n}"
        },
        "url": {
          "raw": "{{gateway_url}}/{{service_path}}/favoritos/{{id_patrimonio}}",
          "host": [
